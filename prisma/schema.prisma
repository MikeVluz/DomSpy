generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  super_admin
  admin
  viewer
}

enum UserStatus {
  active
  pending
  disabled
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  name            String
  role            UserRole         @default(viewer)
  status          UserStatus       @default(pending)
  dismissedAlerts DismissedAlert[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Domain {
  id          String         @id @default(cuid())
  url         String
  name        String
  pages       Page[]
  crawls      CrawlSession[]
  alerts      DismissedAlert[]
  groups      PageGroup[]
  createdAt   DateTime       @default(now())
  lastCrawlAt DateTime?
}

model Page {
  id              String           @id @default(cuid())
  url             String
  domainId        String
  domain          Domain           @relation(fields: [domainId], references: [id], onDelete: Cascade)
  statusCode      Int?
  responseTime    Int?
  title           String?
  description     String?
  h1              String?
  headings        String?
  bodyText        String?
  images          String?
  contentHash     String?
  parentPageId    String?
  parentPage      Page?            @relation("PageTree", fields: [parentPageId], references: [id])
  childPages      Page[]           @relation("PageTree")
  linksFrom       Link[]           @relation("FromPage")
  linksTo         Link[]           @relation("ToPage")
  crawlId         String?
  crawl           CrawlSession?    @relation(fields: [crawlId], references: [id])
  dismissedAlerts DismissedAlert[]
  groupMembers    PageGroupMember[]
  funnelPages     FunnelPage[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([url, domainId])
}

model Link {
  id         String  @id @default(cuid())
  fromPageId String
  fromPage   Page    @relation("FromPage", fields: [fromPageId], references: [id], onDelete: Cascade)
  toPageId   String?
  toPage     Page?   @relation("ToPage", fields: [toPageId], references: [id])
  href       String
  statusCode Int?
  isExternal Boolean @default(false)
  isRedirect Boolean @default(false)
  anchor     String?
}

model CrawlSession {
  id          String    @id @default(cuid())
  domainId    String
  domain      Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  pages       Page[]
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  totalPages  Int       @default(0)
  brokenLinks Int       @default(0)
  slowPages   Int       @default(0)
  status      String    @default("running")
}

model DismissedAlert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  domainId    String
  domain      Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  alertType   String
  dismissedAt DateTime @default(now())

  @@unique([userId, pageId, alertType])
}

model PageGroup {
  id        String      @id @default(cuid())
  name      String
  color     String      @default("#3B82F6")
  domainId  String
  domain    Domain      @relation(fields: [domainId], references: [id], onDelete: Cascade)
  pages     PageGroupMember[]
  createdAt DateTime    @default(now())
}

model PageGroupMember {
  id        String    @id @default(cuid())
  pageId    String
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  groupId   String
  group     PageGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([pageId, groupId])
}

model Funnel {
  id          String       @id @default(cuid())
  name        String
  description String?
  color       String       @default("#3B82F6")
  pages       FunnelPage[]
  linksFrom   FunnelLink[] @relation("FunnelFrom")
  linksTo     FunnelLink[] @relation("FunnelTo")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model FunnelPage {
  id        String  @id @default(cuid())
  funnelId  String
  funnel    Funnel  @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  pageId    String
  page      Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  position  Int     @default(0)

  @@unique([funnelId, pageId])
}

model FunnelLink {
  id           String @id @default(cuid())
  fromFunnelId String
  fromFunnel   Funnel @relation("FunnelFrom", fields: [fromFunnelId], references: [id], onDelete: Cascade)
  toFunnelId   String
  toFunnel     Funnel @relation("FunnelTo", fields: [toFunnelId], references: [id], onDelete: Cascade)

  @@unique([fromFunnelId, toFunnelId])
}
